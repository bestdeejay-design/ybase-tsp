{
    "name": "yell/parser",
    "description": "Parser for yell.ru business directory",
    "type": "project",
    "require": {
        "php": "^8.4",
        "guzzlehttp/guzzle": "^7.8",
        "symfony/dom-crawler": "^7.0",
        "symfony/css-selector": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "YellParser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YellParser\\Tests\\": "tests/"
        }
    }
}
